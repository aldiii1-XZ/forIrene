{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/galaxy$",
      "dest": "/galaxy.html"
    },
    {
      "handle": "filesystem"
    }
  ]
}
